# =============================================================================
# WAS CONTABIL — Variaveis de ambiente PRODUCAO
# Copie para .env e preencha os valores reais
# =============================================================================

# Django
DJANGO_SECRET_KEY=gerar-com-python-c-"from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SETTINGS_MODULE=config.settings.production
DEBUG=False
ALLOWED_HOSTS=simulador.was.dev.br

# Banco de dados
DB_NAME=was_contabil
DB_USER=was_contabil
DB_PASSWORD=GERAR_SENHA_FORTE_AQUI
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=SEU_TOKEN_DO_TUNNEL_AQUI

# OAuth Google (console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth Microsoft (portal.azure.com)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
